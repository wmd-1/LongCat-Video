# ============================================================
# LongCat-Video Docker 环境变量配置
# 复制此文件为 .env 并根据实际情况修改
#   cp .env.example .env
# ============================================================

# ---- 模型权重目录 (必填) ----
# 指向包含 LongCat-Video / LongCat-Video-Avatar / LongCat-Video-Avatar-1.5 的父目录
# 目录结构示例:
#   weights/
#   ├── LongCat-Video/
#   ├── LongCat-Video-Avatar/
#   └── LongCat-Video-Avatar-1.5/
WEIGHTS_DIR=./weights

# ---- 输出目录 ----
# 生成的视频保存到宿主机的目录
OUTPUT_DIR=./outputs

# ---- 输入资源目录 ----
# 挂载自定义图片、音频、JSON 输入文件
ASSETS_DIR=./assets

# ---- Streamlit 端口 ----
STREAMLIT_PORT=8501

# ---- 分布式推理配置 ----
# 多卡推理时按需修改, 单卡无需改动
MASTER_ADDR=127.0.0.1
MASTER_PORT=29500
